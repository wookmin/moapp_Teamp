rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isFridgeOwner(ownerUid) {
      return isSignedIn() && request.auth.uid == ownerUid;
    }

    function isFridgeMember(ownerUid) {
      return isFridgeOwner(ownerUid)
        || (
          isSignedIn()
          && exists(
            /databases/$(database)/documents/users/$(ownerUid)
              /fridge_members/$(request.auth.uid)
          )
        );
    }

    function canEditFridge(ownerUid) {
      return isFridgeOwner(ownerUid)
        || (
          isSignedIn()
          && get(
            /databases/$(database)/documents/users/$(ownerUid)
              /fridge_members/$(request.auth.uid)
          ).data.role == 'editor'
        );
    }

    function validNickname() {
      return request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 2
        && request.resource.data.nickname.size() <= 12
        && request.resource.data.nickname.matches('^[가-힣A-Za-z0-9_]+$')
        && request.resource.data.name == request.resource.data.nickname;
    }

    function nicknameFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['nickname', 'name', 'nicknameChangedAt']);
    }

    function canChangeNickname() {
      return validNickname()
        && request.resource.data.nicknameChangedAt == request.time
        && (
          !('nickname' in resource.data)
          || !('nicknameChangedAt' in resource.data)
          || request.time >= resource.data.nicknameChangedAt + duration.value(7, 'd')
        );
    }

    match /ingredient_search_index/{keywordId} {
      allow read: if true;
      allow write: if false;
    }

    match /ingredients/{ingredientId} {
      allow read: if true;
      allow write: if false;

      match /storage_rules/{ruleId} {
        allow read: if true;
        allow write: if false;
      }

      match /sources/{sourceId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn()
          && request.auth.uid == resource.data.authorUid;
      }
    }

    match /fridge_invite_codes/{inviteCode} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && (
          !('nickname' in request.resource.data)
          || (
            validNickname()
            && request.resource.data.nicknameChangedAt == request.time
          )
        );
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && (
          !nicknameFieldsChanged()
          || canChangeNickname()
        );

      match /food_items/{foodItemId} {
        allow read: if isFridgeMember(userId);
        allow create, update, delete: if canEditFridge(userId);
      }

      match /shopping_cart_items/{cartItemId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /fridge_access/{ownerUid} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /fridge_members/{memberUid} {
        allow read: if isSignedIn()
          && (request.auth.uid == userId || request.auth.uid == memberUid);
        allow create: if isSignedIn()
          && request.auth.uid == memberUid
          && request.resource.data.inviteCode is string
          && exists(
            /databases/$(database)/documents/fridge_invite_codes/$(request.resource.data.inviteCode)
          )
          && get(
            /databases/$(database)/documents/fridge_invite_codes/$(request.resource.data.inviteCode)
          ).data.ownerUid == userId
          && get(
            /databases/$(database)/documents/fridge_invite_codes/$(request.resource.data.inviteCode)
          ).data.active == true
          && get(
            /databases/$(database)/documents/fridge_invite_codes/$(request.resource.data.inviteCode)
          ).data.expiresAt > request.time
          && request.resource.data.role == get(
            /databases/$(database)/documents/fridge_invite_codes/$(request.resource.data.inviteCode)
          ).data.role;
        allow update, delete: if isFridgeOwner(userId);
      }

      match /fridge_invites/{inviteCode} {
        allow read: if isSignedIn();
        allow create, update, delete: if isFridgeOwner(userId);
      }
    }
  }
}
